# Baserow Migration Environment Variables
# Copy this file to .env and fill in the values

# PostgreSQL connection
PGHOST=localhost
PGPORT=5432
PGDATABASE=kokonut_intelligence
PGUSER=kokonut
PGPASSWORD=your_postgres_password_here

# Baserow API
BASEROW_URL=https://api.baserow.io
BASEROW_TOKEN=your_baserow_token_here

# Directus (for migrate.py)
ADMIN_EMAIL=admin@kokonut.network
ADMIN_PASSWORD=your_directus_admin_password_here
