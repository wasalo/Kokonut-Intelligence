# === Runtime ===
# development (default) allows local dev password fallbacks; production requires all secrets
KOKONUT_ENV=development

# === Core Infrastructure ===
POSTGRES_PASSWORD=changeme-postgres-secret
DIRECTUS_SECRET=changeme-directus-secret-min-32-chars
ADMIN_EMAIL=admin@kokonut.network
ADMIN_PASSWORD=changeme-admin-password
PUBLIC_URL=http://localhost:8055

# === ClickHouse ===
CLICKHOUSE_PASSWORD=changeme-clickhouse-secret

# === Baserow Migration ===
BASEROW_API_URL=https://api.baserow.io
BASEROW_TOKEN=your-baserow-database-token

# === Weather ===
OpenWeatherMap_API_KEY=your-openweathermap-api-key

# === External Data Ingestion ===
# RPC endpoints — free public endpoints (no API key required)
# For production, use dedicated providers (Alchemy, Infura, QuickNode)
ETH_RPC_URL=https://eth.llamarpc.com
OPTIMISM_RPC_URL=https://mainnet.optimism.io
BASE_RPC_URL=https://mainnet.base.org
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
CELO_RPC_URL=https://forno.celo.org
CELO_ALFAJORES_RPC_URL=https://alfajores-forno.celo.org

# EAS attestation endpoints
EAS_GRAPHQL_URL=https://attest.sh

# EAS Attestation (Celo primary)
ATTESTER_PRIVATE_KEY=your-attester-private-key
EAS_RESOLVER_ADDRESS=0x...  # filled after KokonutResolver deploy

# === Web3 RPC (Production — get your own keys) ===
# ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# OPTIMISM_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY
# BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
# CELO_RPC_URL=https://celo-mainnet.g.alchemy.com/v2/YOUR_KEY

# === Metabase ===
METABASE_EMBEDDING_SECRET_KEY=changeme-metabase-embedding-secret-32-chars-min
# MB_DB_TYPE=postgres
